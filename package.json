{
  "name": "@nukeviet/ckeditor5-nvtools",
  "version": "48.2.0",
  "description": "Some tools for writing in NukeViet.",
  "keywords": [
    "nukeviet",
    "nukeviet 4",
    "nukeviet 4.5",
    "nukeviet 4.6",
    "nukeviet 5",
    "nukeviet ckeditor",
    "nukeviet ckeditor5"
  ],
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./*": "./dist/*",
    "./browser/*": null,
    "./package.json": "./package.json"
  },
  "peerDependencies": {
    "@ckeditor/ckeditor5-core": "48.2.0",
    "ckeditor5": "48.2.0"
  },
  "files": [
    "dist",
    "ckeditor5-metadata.json"
  ],
  "engines": {
    "node": ">=24.11.0"
  },
  "devDependencies": {
    "@ckeditor/ckeditor5-core": "latest",
    "@ckeditor/ckeditor5-dev-build-tools": "56.1.0",
    "@ckeditor/ckeditor5-dev-translations": "56.1.0",
    "@ckeditor/ckeditor5-inspector": "^5.0.1",
    "@typescript-eslint/parser": "^8.32.1",
    "@vitest/browser-webdriverio": "^4.1.0",
    "@vitest/coverage-istanbul": "^4.1.0",
    "ckeditor5": "latest",
    "eslint": "^9.27.0",
    "eslint-config-ckeditor5": "^15.1.0",
    "eslint-plugin-ckeditor5-rules": "^15.1.0",
    "globals": "^16.1.0",
    "husky": "^4.2.5",
    "lint-staged": "^10.2.6",
    "stylelint": "^16.0.0",
    "stylelint-config-ckeditor5": "^15.1.0",
    "typescript": "5.5.4",
    "vite": "^8.0.0",
    "vite-plugin-svgo": "^1.0.5",
    "vitest": "^4.1.0",
    "webdriverio": "^9.19.2"
  },
  "overrides": {
    "sugarss": "^5.0.1"
  },
  "author": "VINADES.,JSC (https://vinades.vn/)",
  "license": "GPL-2.0-or-later",
  "homepage": "https://nukeviet.vn/",
  "bugs": "https://github.com/nukeviet/nukeviet/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/nukeviet/ckeditor5-nvtools.git"
  },
  "scripts": {
    "start": "vite",
    "build": "npm run build:types && npm run build:npm && npm run build:browser",
    "build:npm": "vite build --mode npm",
    "build:browser": "vite build --mode browser",
    "build:types": "tsc -p tsconfig.build.json",
    "test": "vitest",
    "test:debug": "vitest --inspect-brk --no-file-parallelism --browser.headless=false",
    "lint": "eslint",
    "stylelint": "stylelint --quiet --allow-empty-input 'theme/**/*.css'",
    "translations:synchronize": "node ./scripts/synchronize-translations.js",
    "translations:validate": "node ./scripts/synchronize-translations.js --validate-only",
    "prepublishOnly": "npm run build"
  },
  "lint-staged": {
    "**/*": [
      "eslint"
    ],
    "**/*.css": [
      "stylelint --quiet --allow-empty-input"
    ]
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  }
}
